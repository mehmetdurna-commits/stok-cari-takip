APP_ENV=development
FLASK_DEBUG=0

# Public site info (SEO)
SITE_URL=https://www.maxad.com
SITE_NAME=StokCari
SITE_DESCRIPTION=Stok, cari, POS ve teklif yönetimi için web tabanlı işletme uygulaması.
# Optional absolute URL:
# SITE_OG_IMAGE=https://www.maxad.com/static/og.svg

# Required in production. Generate unique values before deployment.
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
SECURITY_PASSWORD_SALT=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_VALUE

# Platform owner/admin bootstrap
# Comma-separated emails. Example: admin@maxad.com,owner@maxad.com
PLATFORM_ADMIN_EMAILS=CHANGE_ME@example.com
PLATFORM_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
# Optional display info
PLATFORM_ADMIN_COMPANY=Maxad A.S.
PLATFORM_ADMIN_NAME=Maxad Owner

# Database. SQLite is convenient locally; use PostgreSQL in production.
DATABASE_URL=sqlite:///stokcari.db

# Cookies / sessions
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
SESSION_HOURS=12

# Reverse proxy (Nginx) -> app
USE_PROXY_FIX=0

# CSRF protection
WTF_CSRF_ENABLED=1
WTF_CSRF_TIME_LIMIT=3600
