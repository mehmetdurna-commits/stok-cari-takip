APP_ENV=development
FLASK_DEBUG=0

# Public site info (SEO)
SITE_URL=https://www.esstok.com
SITE_NAME=Esstok
SITE_DESCRIPTION=Küçük işletmeler için bulut tabanlı stok, cari, POS ve personel yönetimi.
# Optional absolute URL:
# SITE_OG_IMAGE=https://www.esstok.com/static/og.svg

# Required in production. Generate unique values before deployment.
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
SECURITY_PASSWORD_SALT=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_VALUE

# Platform owner/admin bootstrap
# Comma-separated emails. Example: admin@esstok.com,owner@esstok.com
PLATFORM_ADMIN_EMAILS=CHANGE_ME@example.com
PLATFORM_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
# Optional display info
PLATFORM_ADMIN_COMPANY=Esstok
PLATFORM_ADMIN_NAME=Esstok Owner

# Database. SQLite is convenient locally; use PostgreSQL in production.
DATABASE_URL=sqlite:///stokcari.db

# Cookies / sessions
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
SESSION_HOURS=12

# Reverse proxy (Nginx) -> app
USE_PROXY_FIX=0

# CSRF protection
WTF_CSRF_ENABLED=1
WTF_CSRF_TIME_LIMIT=3600

# Outbound email branding
SMTP_FROM_NAME=Esstok