[Unit]
Description=StokCari (Gunicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/stokcari/current

EnvironmentFile=/opt/stokcari/shared/.env
Environment=PYTHONUNBUFFERED=1
Environment=USE_PROXY_FIX=1

ExecStart=/opt/stokcari/shared/.venv/bin/gunicorn -c /opt/stokcari/current/gunicorn.conf.py wsgi:application
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
